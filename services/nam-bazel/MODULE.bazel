    name = "lilv",
    commit = "5318c9e495c5404d7f0a623aeba2a8f617a26a9d",
    remote = "https://github.com/drobilla/lilv",
    build_file = "@//thirdparty:lilv.BUILD",
)

# suil - LV2 UI library
git_repository(
    name = "suil",
    commit = "3100c21f864aacbeece57a3bd93af340074f34cb",
    remote = "https://github.com/drobilla/suil",
    build_file = "@//thirdparty:suil.BUILD",
)
