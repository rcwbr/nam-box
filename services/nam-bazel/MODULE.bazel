    commit = "a4fab097251f8b8218d3838b40cce5ef39e56aaf",
    remote = "https://github.com/drobilla/zix",
    build_file = "@//thirdparty:zix.BUILD",
)

# serd - RDF library for LV2
git_repository(
    name = "serd",
    commit = "0317806d56f9288294183b41074a6fd50a924f5a",
    remote = "https://github.com/drobilla/serd",
    build_file = "@//thirdparty:serd.BUILD",
)

# sord - RDF store for LV2
git_repository(
    name = "sord",
    commit = "c9b049b3ac758cafe354cdf019422febd99abe45",
    remote = "https://github.com/drobilla/sord",
    build_file = "@//thirdparty:sord.BUILD",
)

# sratom - LV2 Atom serialization
git_repository(
    name = "sratom",
    commit = "9e8ee84eed502e6030ce8bb49694fd28542b08fc",
